{
  "permissions": {
    "allow": [
      "Bash(npm --version)",
      "Bash(npm create *)",
      "Bash(npx create-vite@latest frontend --template react-ts)",
      "Bash(npx create-vite@5 frontend --template react-ts)",
      "Bash(npx tailwindcss *)",
      "Bash(node node_modules/.bin/tailwindcss init -p)",
      "Bash(Select-String -Pattern \"tailwind\")",
      "Bash(npm run *)",
      "Bash(npx ts-node-dev *)",
      "Bash(Get-Process -Name \"node\" -ErrorAction SilentlyContinue)",
      "Bash(Stop-Process -Force)",
      "Bash(Start-Sleep -Seconds 2)",
      "Bash(awk '{print $NF}')",
      "Bash(xargs -I{} taskkill /PID {} /F)",
      "Bash(taskkill /PID 12108 /F)",
      "Bash(taskkill /PID 7268 /F)",
      "Bash(cmd /c \"taskkill /PID 12108 /F && taskkill /PID 7268 /F\")",
      "Bash(cmd /c \"taskkill /IM node.exe /F\")"
    ]
  }
}
